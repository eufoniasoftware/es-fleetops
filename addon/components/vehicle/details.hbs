<div class="details-wrapper" ...attributes>
    {{! CORE DETAILS }}
    <ContentPanel @title={{t "common.details"}} @open={{true}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">
            {{! Vehicle Identification }}
            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                {{t "vehicle.sections.identification"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "common.name"}}</div>
                <div class="field-value">{{n-a @resource.name}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "common.internal-id"}}</div>
                <div class="field-value">{{n-a @resource.internal_id}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.plate-number"}}</div>
                <div class="field-value">{{n-a @resource.plate_number}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.vin-number"}}</div>
                <div class="field-value">{{n-a @resource.vin}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.make"}}</div>
                <div class="field-value">{{n-a @resource.make}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.model"}}</div>
                <div class="field-value">{{n-a @resource.model}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.year"}}</div>
                <div class="field-value">{{n-a @resource.year}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.trim"}}</div>
                <div class="field-value">{{n-a @resource.trim}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.color"}}</div>
                <div class="field-value">{{n-a @resource.color}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.serial-number"}}</div>
                <div class="field-value">{{n-a @resource.serial_number}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.class"}}</div>
                <div class="field-value">{{n-a @resource.class}}</div>
            </div>

            {{! Assignment & Status }}
            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                {{t "vehicle.sections.assignment-status"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.driver-assigned"}}</div>
                <div class="field-value">
                    {{n-a (or @resource.driver.name @resource.driver_name)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "common.status"}}</div>
                <div class="field-value">{{n-a (smart-humanize @resource.status)}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.call-sign"}}</div>
                <div class="field-value">{{n-a @resource.call_sign}}</div>
            </div>

            {{! Location }}
            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                {{t "vehicle.sections.location"}}
            </div>

            <div class="field-info-container col-span-2">
                <div class="field-name">
                    {{t "common.coordinates"}}
                </div>
                <div class="field-value">
                    {{point-coordinates @resource.location}}
                </div>
            </div>
        </div>
    </ContentPanel>

    {{! MEASUREMENT, UNITS & ODOMETER }}
    <ContentPanel @title={{t "vehicle.sections.measurement-units"}} @open={{false}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">
            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                {{t "vehicle.sections.measurement-units"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.system-of-measurement"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "measurementSystems" @resource.measurement_system)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.fuel-volume-unit"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "fuelVolumeUnits" @resource.fuel_volume_unit)}}
                </div>
            </div>

            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                {{t "vehicle.sections.odometer-usage"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">
                    {{t "vehicle.fields.current-odometer"}} ({{@resource.odometer_unit}})
                </div>
                <div class="field-value">
                    {{n-a @resource.odometer}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.odometer-unit"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "odometerUnits" @resource.odometer_unit)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.odometer-at-purchase"}}</div>
                <div class="field-value">{{n-a @resource.odometer_at_purchase}}</div>
            </div>
        </div>
    </ContentPanel>

    {{! BODY & USAGE }}
    <ContentPanel @title={{t "vehicle.sections.body-usage"}} @open={{false}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">
            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                {{t "vehicle.sections.body-usage"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.body-type"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "vehicleBodyTypes" @resource.body_type)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.body-subtype"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "vehicleBodySubTypes" @resource.body_sub_type)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.usage-type"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "vehicleUsageTypes" @resource.usage_type)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.ownership-type"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "vehicleOwnershipTypes" @resource.ownership_type)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.fuel-type"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "fuelTypes" @resource.fuel_type)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.transmission"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "transmissionTypes" @resource.transmission)}}
                </div>
            </div>
        </div>
    </ContentPanel>

    {{! TECHNICAL SPECIFICATIONS }}
    <ContentPanel @title={{t "vehicle.sections.tech-specs"}} @open={{false}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-2 text-xs dark:text-gray-100">

            {{! Powertrain & Engine }}
            <div class="col-span-3 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                {{t "vehicle.sections.powertrain-engine"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.engine-number"}}</div>
                <div class="field-value">{{n-a @resource.engine_number}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.engine-make"}}</div>
                <div class="field-value">{{n-a @resource.engine_make}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.engine-model"}}</div>
                <div class="field-value">{{n-a @resource.engine_model}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.engine-family"}}</div>
                <div class="field-value">{{n-a @resource.engine_family}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.engine-configuration"}}</div>
                <div class="field-value">{{n-a @resource.engine_configuration}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.cylinder-arrangement"}}</div>
                <div class="field-value">{{n-a @resource.cylinder_arrangement}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.number-of-cylinders"}}</div>
                <div class="field-value">{{n-a @resource.number_of_cylinders}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.engine-size"}}</div>
                <div class="field-value">
                    {{#if @resource.engine_size}}
                        {{@resource.engine_size}}
                        L
                    {{else}}
                        {{n-a @resource.engine_size}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.engine-displacement"}}</div>
                <div class="field-value">
                    {{#if @resource.engine_displacement}}
                        {{@resource.engine_displacement}}
                        cc
                    {{else}}
                        {{n-a @resource.engine_displacement}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.horsepower"}}</div>
                <div class="field-value">
                    {{#if @resource.horsepower}}
                        {{@resource.horsepower}}
                        hp
                    {{else}}
                        {{n-a @resource.horsepower}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.horsepower-rpm"}}</div>
                <div class="field-value">{{n-a @resource.horsepower_rpm}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.torque"}}</div>
                <div class="field-value">
                    {{#if @resource.torque}}
                        {{@resource.torque}}
                        Nm
                    {{else}}
                        {{n-a @resource.torque}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.torque-rpm"}}</div>
                <div class="field-value">{{n-a @resource.torque_rpm}}</div>
            </div>

            {{! Capacity & Dimensions }}
            <div class="col-span-3 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                {{t "vehicle.sections.capacity-dimensions"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.fuel-capacity"}}</div>
                <div class="field-value">
                    {{#if @resource.fuel_capacity}}
                        {{@resource.fuel_capacity}}
                        L
                    {{else}}
                        {{n-a @resource.fuel_capacity}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.payload-capacity"}}</div>
                <div class="field-value">
                    {{#if @resource.payload_capacity}}
                        {{@resource.payload_capacity}}
                        kg
                    {{else}}
                        {{n-a @resource.payload_capacity}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.towing-capacity"}}</div>
                <div class="field-value">
                    {{#if @resource.towing_capacity}}
                        {{@resource.towing_capacity}}
                        kg
                    {{else}}
                        {{n-a @resource.towing_capacity}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.seating-capacity"}}</div>
                <div class="field-value">{{n-a @resource.seating_capacity}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.vehicle-weight"}}</div>
                <div class="field-value">
                    {{#if @resource.weight}}
                        {{@resource.weight}}
                        kg
                    {{else}}
                        {{n-a @resource.weight}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.length"}}</div>
                <div class="field-value">
                    {{#if @resource.length}}
                        {{@resource.length}}
                        cm
                    {{else}}
                        {{n-a @resource.length}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.width"}}</div>
                <div class="field-value">
                    {{#if @resource.width}}
                        {{@resource.width}}
                        cm
                    {{else}}
                        {{n-a @resource.width}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.height"}}</div>
                <div class="field-value">
                    {{#if @resource.height}}
                        {{@resource.height}}
                        cm
                    {{else}}
                        {{n-a @resource.height}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.cargo-volume"}}</div>
                <div class="field-value">
                    {{#if @resource.cargo_volume}}
                        {{@resource.cargo_volume}}
                        L
                    {{else}}
                        {{n-a @resource.cargo_volume}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.passenger-volume"}}</div>
                <div class="field-value">
                    {{#if @resource.passenger_volume}}
                        {{@resource.passenger_volume}}
                        L
                    {{else}}
                        {{n-a @resource.passenger_volume}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.interior-volume"}}</div>
                <div class="field-value">
                    {{#if @resource.interior_volume}}
                        {{@resource.interior_volume}}
                        L
                    {{else}}
                        {{n-a @resource.interior_volume}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.ground-clearance"}}</div>
                <div class="field-value">
                    {{#if @resource.ground_clearance}}
                        {{@resource.ground_clearance}}
                        cm
                    {{else}}
                        {{n-a @resource.ground_clearance}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.bed-length"}}</div>
                <div class="field-value">
                    {{#if @resource.bed_length}}
                        {{@resource.bed_length}}
                        cm
                    {{else}}
                        {{n-a @resource.bed_length}}
                    {{/if}}
                </div>
            </div>

            {{! Regulatory & Compliance }}
            <div class="col-span-3 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                {{t "vehicle.sections.regulatory-compliance"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.emission-standard"}}</div>
                <div class="field-value">{{n-a @resource.emission_standard}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.dpf-equipped"}}</div>
                <div class="field-value">
                    {{#if (eq @resource.dpf_equipped true)}}
                        {{t "common.yes"}}
                    {{else if (eq @resource.dpf_equipped false)}}
                        {{t "common.no"}}
                    {{else}}
                        -
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.scr-equipped"}}</div>
                <div class="field-value">
                    {{#if (eq @resource.scr_equipped true)}}
                        {{t "common.yes"}}
                    {{else if (eq @resource.scr_equipped false)}}
                        {{t "common.no"}}
                    {{else}}
                        -
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.gvwr"}}</div>
                <div class="field-value">
                    {{#if @resource.gvwr}}
                        {{@resource.gvwr}}
                        kg
                    {{else}}
                        {{n-a @resource.gvwr}}
                    {{/if}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.gcwr"}}</div>
                <div class="field-value">
                    {{#if @resource.gcwr}}
                        {{@resource.gcwr}}
                        kg
                    {{else}}
                        {{n-a @resource.gcwr}}
                    {{/if}}
                </div>
            </div>
        </div>
    </ContentPanel>

    {{! FINANCIAL & LIFECYCLE }}
    <ContentPanel @title={{t "vehicle.sections.financial-lifecycle"}} @open={{false}} @wrapperClass="bordered-top">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 text-xs dark:text-gray-100">
            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-1">
                {{t "vehicle.sections.asset-values"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.acquisition-cost"}}</div>
                <div class="field-value">
                    {{format-currency @resource.acquisition_cost @resource.currency}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.current-value"}}</div>
                <div class="field-value">
                    {{format-currency @resource.current_value @resource.currency}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.insurance-value"}}</div>
                <div class="field-value">
                    {{format-currency @resource.insurance_value @resource.currency}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.depreciation-rate"}}</div>
                <div class="field-value">{{n-a @resource.depreciation_rate}}</div>
            </div>

            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                {{t "vehicle.sections.lifecycle-service-life"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.estimated-service-life-distance"}}</div>
                <div class="field-value">{{n-a @resource.estimated_service_life_distance}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.service-life-distance-unit"}}</div>
                <div class="field-value">
                    {{n-a (get-fleet-ops-option-label "odometerUnits" @resource.estimated_service_life_distance_unit)}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.estimated-service-life-months"}}</div>
                <div class="field-value">{{n-a @resource.estimated_service_life_months}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.purchase-date"}}</div>
                <div class="field-value">
                    {{n-a (format-date-fns @resource.purchased_at "dd-MM-yyyy")}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.lease-expiry-date"}}</div>
                <div class="field-value">
                    {{n-a (format-date-fns @resource.lease_expires_at "dd-MM-yyyy")}}
                </div>
            </div>

            <div class="col-span-2 text-[11px] uppercase tracking-wide text-gray-500 font-semibold mt-3">
                {{t "vehicle.sections.financing-loan"}}
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.loan-amount"}}</div>
                <div class="field-value">
                    {{format-currency @resource.loan_amount @resource.currency}}
                </div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.number-of-payments"}}</div>
                <div class="field-value">{{n-a @resource.loan_number_of_payments}}</div>
            </div>

            <div class="field-info-container">
                <div class="field-name">{{t "vehicle.fields.first-payment-date"}}</div>
                <div class="field-value">
                    {{n-a (format-date-fns @resource.loan_first_payment "dd-MM-yyyy")}}
                </div>
            </div>
        </div>
    </ContentPanel>

    {{! CUSTOM FIELDS (view mode) }}
    <CustomField::Yield @subject={{@resource}} @viewMode={{true}} @wrapperClass="bordered-top" />

    {{! AVATAR }}
    <ContentPanel @title={{t "common.avatar"}} @open={{true}} @wrapperClass="bordered-top">
        <div class="flex px-1">
            <div class="border border-dashed border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-600 rounded-lg flex items-center justify-center">
                <div class="flex items-center justify-center h-20 w-24">
                    <Image
                        alt={{@resource.displayName}}
                        src={{or @resource.avatar_custom_url @resource.avatar_url}}
                        @fallbackSrc={{config "defaultValues.vehicleAvatar"}}
                        class="w-12 h-12"
                    />
                </div>
            </div>
        </div>
    </ContentPanel>

    <RegistryYield @registry="fleet-ops:component:vehicle:details" as |RegistryComponent|>
        <RegistryComponent @resource={{@resource}} @controller={{@controller}} @permission={{get-write-permission @resource}} />
    </RegistryYield>

    {{! METADATA }}
    <ContentPanel
        @title={{t "common.metadata"}}
        @open={{true}}
        @actionButtons={{this.metadataButtons}}
        @wrapperClass="bordered-top"
        @panelBodyWrapperClass={{unless (is-object-empty @resource.meta) "px-0i" ""}}
    >
        <MetadataViewer @metadata={{@resource.meta}} />
    </ContentPanel>

    <Spacer @height="300px" />
</div>