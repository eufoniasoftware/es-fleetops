<div class="form-wrapper" ...attributes>
    <ContentPanel @title={{t "equipment.fields.equipment-details"}} @open={{true}} @wrapperClass="bordered-top">
        <div class="flex flex-row space-x-3 mb-3">
            <div class="flex items-center justify-start rounded-full">
                <Image src={{@resource.photo_url}} @fallbackSrc={{config "defaultValues.equipmentImage"}} alt={{@resource.name}} height="48" width="48" class="h-14 w-14 rounded-full shadow-sm" />
                <Attach::Tooltip @class="clean" @animation="scale" @placement="top">
                    <InputInfo @text={{t "equipment.fields.upload-new-photo"}} />
                </Attach::Tooltip>
            </div>
            <div>
                <UploadButton
                    @name={{t "common.photos"}}
                    @accept="image/*"
                    @onFileAdded={{perform this.handlePhotoUpload}}
                    @icon="upload"
                    @size="xs"
                    @buttonText={{t "common.upload-image"}}
                    @disabled={{cannot-write @resource}}
                />
                <div class="px-1">
                    <span class="text-gray-300 dark:text-gray-600 text-xs">{{t "common.upload-image-supported"}}</span>
                </div>
            </div>
        </div>
        <div class="grid grid-cols-1 gap-2 lg:grid-cols-2 lg:gap-2 no-input-group-padding text-xs">
            <InputGroup @name={{t "equipment.fields.name"}} @wrapperClass="col-span-2">
                <Input @value={{@resource.name}} @type="text" class="w-full form-input" placeholder={{t "equipment.fields.name"}} disabled={{cannot-write @resource}} />
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.code"}}>
                <Input @value={{@resource.code}} @type="text" class="w-full form-input" placeholder={{t "equipment.fields.equipment-code"}} disabled={{cannot-write @resource}} />
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.type"}}>
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.equipmentTypeOptions}}
                        @selected={{@resource.type}}
                        @onChange={{fn (mut @resource.type)}}
                        @placeholder={{t "equipment.fields.select-equipment-type"}}
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |type|
                    >
                        {{smart-humanize type}}
                    </PowerSelect>
                </div>
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.status"}}>
                <div class="fleetbase-model-select fleetbase-power-select ember-model-select">
                    <PowerSelect
                        @options={{this.statusOptions}}
                        @selected={{@resource.status}}
                        @onChange={{fn (mut @resource.status)}}
                        @placeholder={{t "equipment.fields.select-status"}}
                        @triggerClass="form-select form-input"
                        @disabled={{cannot-write @resource}}
                        as |status|
                    >
                        {{smart-humanize status}}
                    </PowerSelect>
                </div>
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.serial-number"}}>
                <Input @value={{@resource.serial_number}} @type="text" class="w-full form-input" placeholder={{t "equipment.fields.serial-number"}} disabled={{cannot-write @resource}} />
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.manufacturer"}}>
                <Input @value={{@resource.manufacturer}} @type="text" class="w-full form-input" placeholder={{t "equipment.fields.manufacturer"}} disabled={{cannot-write @resource}} />
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.model"}}>
                <Input @value={{@resource.model}} @type="text" class="w-full form-input" placeholder={{t "equipment.fields.model"}} disabled={{cannot-write @resource}} />
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.purchased-at"}}>
                <DatePicker
                    @value={{@resource.purchased_at}}
                    @onChange={{fn (mut @resource.purchased_at)}}
                    @placeholder={{t "equipment.fields.select-purchase-date"}}
                    @disabled={{cannot-write @resource}}
                    class="w-full form-input"
                />
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.purchase-price"}}>
                <MoneyInput
                    class="w-full"
                    @value={{@resource.purchase_price}}
                    @currency={{or @resource.currency "USD"}}
                    @canSelectCurrency={{true}}
                    @onCurrencyChange={{fn (mut @resource.currency)}}
                    @disabled={{cannot-write @resource}}
                />
            </InputGroup>

            <InputGroup @name={{t "equipment.fields.warranty"}}>
                <ModelSelect
                    @modelName="warranty"
                    @selectedModel={{@resource.warranty}}
                    @placeholder={{t "equipment.fields.select-warranty"}}
                    @triggerClass="form-select form-input"
                    @infiniteScroll={{false}}
                    @renderInPlace={{true}}
                    @onChange={{fn (mut @resource.warranty)}}
                    @onChangeId={{fn (mut @resource.warranty_uuid)}}
                    @disabled={{cannot-write @resource}}
                    as |model|
                >
                    {{model.policy_number}} - {{model.provider}}
                </ModelSelect>
            </InputGroup>

            <RegistryYield @registry="fleet-ops:component:equipment:form:details" as |RegistryComponent|>
                <RegistryComponent @resource={{@resource}} @controller={{@controller}} @permission={{get-write-permission @resource}} />
            </RegistryYield>
        </div>
    </ContentPanel>

    <CustomField::Yield @subject={{@resource}} @wrapperClass="bordered-top" />

    <RegistryYield @registry="fleet-ops:component:equipment:form" as |RegistryComponent|>
        <RegistryComponent @resource={{@resource}} @controller={{@controller}} @permission={{get-write-permission @resource}} />
    </RegistryYield>
</div>
