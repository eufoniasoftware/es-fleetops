<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    <div class="px-4 text-gray-900 dark:text-gray-50">
        <div class="mb-1 text-base font-semibold">
            {{t "modals.reset-customer-credentials.resetting-for" name=this.customer.name}}
        </div>
        <div class="text-sm mb-4">{{t "modals.reset-customer-credentials.instructions"}}</div>
        <InputGroup>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                <InputGroup @name={{t "modals.reset-customer-credentials.new-password"}} @type="password" @value={{this.password}} @wrapperClass="mb-0i" />
                <InputGroup @name={{t "modals.reset-customer-credentials.confirm-password"}} @type="password" @value={{this.confirmPassword}} @wrapperClass="mb-0i" />
            </div>
        </InputGroup>
        <InputGroup>
            <Checkbox @value={{this.sendCredentials}} @label={{t "modals.reset-customer-credentials.send-credentials"}} @onToggle={{fn (mut this.sendCredentials)}} @alignItems="center" @labelClass="mb-0i" />
        </InputGroup>
    </div>
</Modal::Default>